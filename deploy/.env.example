# Copy to deploy/.env and fill in.

# Your domain. A DNS A record must point at this server before you run
# init-letsencrypt.sh.
DOMAIN=remote.example.com

# Email for Let's Encrypt expiry/renewal notices.
LETSENCRYPT_EMAIL=you@example.com

# TURN credentials — only used when you start the `turn` profile. Must match the
# user/password in deploy/turnserver.conf. Use a long random password.
TURN_USER=remotework
TURN_PASSWORD=change-me-to-a-long-random-string
